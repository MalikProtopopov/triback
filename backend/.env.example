# Environment variables template for development
# Copy to .env and fill in values

# Application
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production
# Fernet key for encrypting bot tokens. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT (RS256 key files relative to backend/)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_AUDIENCE=trihoback-api
JWT_ISSUER=trihoback

# Database
DATABASE_URL=postgresql+asyncpg://triho_user:triho_pass@localhost:5432/triho_db

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO (dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=triho-dev
S3_PUBLIC_URL=http://localhost:9000/triho-dev

# Платежи: по умолчанию Moneta. ЮKassa — только если выставить PAYMENT_PROVIDER=yookassa.
PAYMENT_PROVIDER=moneta

# Moneta — MerchantAPI v2
MONETA_USERNAME=
MONETA_PASSWORD=
MONETA_SERVICE_URL=https://service.moneta.ru/services
MONETA_PAYEE_ACCOUNT=
MONETA_PAYMENT_PASSWORD=
MONETA_MNT_ID=
# База ссылки на MONETA.Assistant (query MNT_*). Должна совпадать с настройками ЛК и тем URL, который открывает клиент.
# Прод: обычно https://www.payanyway.ru/assistant.htm — демо: https://demo.moneta.ru/assistant.htm (или вариант assistant.demo.moneta.ru по инструкции ЛК).
MONETA_ASSISTANT_URL=https://www.payanyway.ru/assistant.htm
MONETA_WIDGET_URL=https://www.payanyway.ru/assistant.widget
MONETA_DEMO_MODE=false
MONETA_WEBHOOK_SECRET=
MONETA_SUCCESS_URL=https://trichology.ru/payment/success
MONETA_FAIL_URL=https://trichology.ru/payment/fail
MONETA_INPROGRESS_URL=
MONETA_RETURN_URL=https://trichology.ru/subscription
MONETA_FORM_VERSION=v3
# Для демо-среды:
# MONETA_DEMO_MODE=true
# MONETA_SERVICE_URL=https://demo.moneta.ru/services
# MONETA_ASSISTANT_URL=https://demo.moneta.ru/assistant.htm
# Если в ЛК указан другой хост (например assistant.demo.moneta.ru) — задайте тот же базовый URL здесь.

# ЮKassa — не заполнять при PAYMENT_PROVIDER=moneta (см. env.prod.example)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_RETURN_URL=https://trichology.ru/payment/result
YOOKASSA_IP_WHITELIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11/32,77.75.156.35/32
# Dev: false (default). Production with YooKassa: true (обязательно в validate при PAYMENT_PROVIDER=yookassa).
YOOKASSA_WEBHOOK_VERIFY_WITH_API=false
PAYMENT_IDEMPOTENCY_TTL=86400
# Через сколько часов неоплаченный платёж считается истёкшим (default: 24)
PAYMENT_EXPIRATION_HOURS=24

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@triho.ru
SMTP_TLS=false

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHANNEL_ID=-100123456789
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# API base URL for webhook URLs and download links (optional). Dev: leave empty.
PUBLIC_API_URL=

# Frontend
FRONTEND_URL=https://trichology.ru
# URL админки (для ссылок в письмах staff). Тест: admin.trichologia.mediann.dev, прод: admin.trichologia.ru
ADMIN_FRONTEND_URL=https://admin.trichologia.mediann.dev

# CORS — оба домена фронтенда (клиент + админка). JSON-массив.
# Dev: клиент на 3000, админка на 3001. ALLOWED_HOSTS — legacy alias для того же списка.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# access_token cookie: none = cross-origin SPA; lax = безопаснее при XSS, если фронт same-site
# ACCESS_TOKEN_COOKIE_SAMESITE=none
