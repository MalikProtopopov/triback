# Dev environment — copy to backend/.env before running: make dev
# Docker-internal hostnames (postgres, redis, minio) instead of localhost

# Domains (used by nginx templates and scripts)
API_DOMAIN=localhost
CERT_EMAIL=dev@localhost

# Application
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# JWT (RS256 key files relative to /app inside container)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Database (Docker hostname: postgres)
DATABASE_URL=postgresql+asyncpg://triho_user:triho_pass@postgres:5432/triho_db

# Postgres container vars
POSTGRES_USER=triho_user
POSTGRES_PASSWORD=triho_pass
POSTGRES_DB=triho_db

# Redis (Docker hostname: redis)
REDIS_URL=redis://redis:6379/0

# S3 / MinIO (Docker hostname: minio)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=triho-dev

# YooKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_RETURN_URL=http://localhost:3000/payment/result
YOOKASSA_IP_WHITELIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11/32,77.75.156.35/32
PAYMENT_IDEMPOTENCY_TTL=86400

# SMTP
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@triho.ru

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_WEBHOOK_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:3001"]
