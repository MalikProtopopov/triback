# Production environment — copy to .env.prod and fill real values
# NEVER commit .env.prod to git
#
# API_DOMAIN is the single source of truth for the backend domain.
# It is used by: nginx templates (envsubst), init-ssl.sh, deploy.sh

# ===== DOMAINS (change only here when switching environments) =====
API_DOMAIN=api.trichologia.ru
# Полный URL API для ссылок в ответах (download_url и т.д.). Тест: https://trihoback.mediann.dev
PUBLIC_API_URL=https://api.trichologia.ru
CERT_EMAIL=admin@trichologia.ru
FRONTEND_URL=https://trichologia.ru
# URL админки (для ссылок в письмах staff). Тест: https://admin.trichologia.mediann.dev
ADMIN_FRONTEND_URL=https://admin.trichologia.ru

# CORS — оба домена фронтенда (клиент + админка). JSON-массив.
ALLOWED_HOSTS=["https://trichologia.ru","https://admin.trichologia.ru"]

# Auth cookies: домен для cross-subdomain (опционально). Прод: .trichologia.ru
# COOKIE_DOMAIN=.trichologia.ru

# ===== APPLICATION =====
DEBUG=false
SECRET_KEY=<random-64-chars: openssl rand -hex 32>
# Fernet key for encrypting bot tokens. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ===== JWT (RS256 key files — volume-mounted into /app/keys) =====
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# ===== DATABASE (Docker hostname: postgres) =====
DATABASE_URL=postgresql+asyncpg://triho_user:<strong-password>@postgres:5432/triho_db
POSTGRES_USER=triho_user
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=triho_db

# ===== REDIS (Docker hostname: redis) =====
REDIS_URL=redis://redis:6379/0

# ===== S3 / MinIO =====
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=triho-prod
S3_PUBLIC_URL=https://api.trichologia.ru/media

# ===== Payment provider =====
PAYMENT_PROVIDER=moneta

# ===== Moneta — MerchantAPI v2 =====
MONETA_USERNAME=<merchant-login>
MONETA_PASSWORD=<merchant-password>
MONETA_SERVICE_URL=https://service.moneta.ru/services
MONETA_PAYEE_ACCOUNT=<extended-account-number>
MONETA_PAYMENT_PASSWORD=<payment-password-from-lk>
MONETA_MNT_ID=<extended-account-number>
MONETA_ASSISTANT_URL=https://www.payanyway.ru/assistant.htm
MONETA_WIDGET_URL=https://www.payanyway.ru/assistant.widget
MONETA_DEMO_MODE=false
MONETA_WEBHOOK_SECRET=<webhook-secret>
MONETA_SUCCESS_URL=https://trichologia.ru/payment/success
MONETA_FAIL_URL=https://trichologia.ru/payment/fail
MONETA_INPROGRESS_URL=
MONETA_RETURN_URL=https://trichologia.ru/subscription
MONETA_FORM_VERSION=v3
# Для демо: раскомментировать и заменить значения
# MONETA_DEMO_MODE=true
# MONETA_SERVICE_URL=https://demo.moneta.ru/services
# MONETA_ASSISTANT_URL=https://demo.moneta.ru/assistant.htm

# ===== Legacy YooKassa (used when PAYMENT_PROVIDER=yookassa) =====
YOOKASSA_SHOP_ID=<shop-id>
YOOKASSA_SECRET_KEY=<secret-key>
YOOKASSA_RETURN_URL=https://trichologia.ru/payment/result
YOOKASSA_IP_WHITELIST=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11/32,77.75.156.35/32
PAYMENT_IDEMPOTENCY_TTL=86400

# ===== SMTP =====
SMTP_HOST=smtp.provider.com
SMTP_PORT=465
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHANNEL_ID=<channel-id>
TELEGRAM_WEBHOOK_SECRET=<webhook-secret>
